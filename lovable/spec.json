{
  "app": {
    "name": "LLM Trace Review Tool",
    "description": "Manual review interface for discovering failure modes in LLM agent traces",
    "version": "1.0.0-mvp",
    "layout": "single-page"
  },
  
  "data_models": {
    "trace": {
      "source": "csv_file",
      "fields": {
        "trace_id": {
          "type": "string",
          "nullable": true,
          "generate_if_empty": "TRACE_{row_number:03d}"
        },
        "customer_persona": {
          "type": "string",
          "nullable": true,
          "display_if_empty": "N/A"
        },
        "user_query": {
          "type": "string",
          "required": true
        },
        "conversation_messages": {
          "type": "string",
          "required": true,
          "format": "delimited",
          "delimiter": " | ",
          "parse_into": "conversation_flow"
        },
        "tool_calls": {
          "type": "string",
          "nullable": true
        }
      }
    },
    
    "conversation_flow": {
      "description": "Parsed representation of conversation_messages",
      "structure": "array",
      "items": {
        "role": {
          "type": "enum",
          "values": ["USER", "ASSISTANT", "AGENT"]
        },
        "content": {
          "type": "string"
        },
        "type": {
          "type": "enum",
          "values": ["message", "tool_call"]
        },
        "tool_name": {
          "type": "string",
          "nullable": true,
          "extract_from": "TOOL_CALL[{tool_name}]"
        },
        "is_error": {
          "type": "boolean",
          "detect_keyword": "Error:"
        },
        "error_message": {
          "type": "string",
          "nullable": true
        }
      }
    },
    
    "annotation": {
      "fields": {
        "trace_id": {
          "type": "string",
          "required": true,
          "foreign_key": "trace.trace_id"
        },
        "status": {
          "type": "enum",
          "values": ["not_reviewed", "pass", "fail", "deferred"],
          "default": "not_reviewed"
        },
        "notes": {
          "type": "text",
          "nullable": true
        },
        "reviewer": {
          "type": "string",
          "default": "Reviewer"
        },
        "reviewed_at": {
          "type": "datetime",
          "auto": true
        },
        "revision_history": {
          "type": "array",
          "items": {
            "timestamp": "datetime",
            "action": "string",
            "old_status": "string",
            "new_status": "string"
          }
        }
      }
    }
  },
  
  "component_hierarchy": {
    "App": {
      "children": [
        "Header",
        "ControlsBar",
        "MainContent",
        "NavigationFooter"
      ]
    },
    
    "Header": {
      "components": [
        "AppTitle",
        "CSVUploader",
        "ProgressSummary"
      ]
    },
    
    "ControlsBar": {
      "components": [
        "SortDropdown",
        "FilterPanel"
      ],
      "layout": "horizontal",
      "sticky": true
    },
    
    "MainContent": {
      "layout": "two-column",
      "left_column": {
        "width": "65%",
        "components": ["TraceDisplay"]
      },
      "right_column": {
        "width": "35%",
        "components": ["MetadataPanel", "FeedbackPanel"]
      }
    },
    
    "TraceDisplay": {
      "components": [
        "SystemPromptSection",
        "UserQuerySection",
        "ConversationFlowSection",
        "FinalResponseSection"
      ]
    },
    
    "ConversationFlowSection": {
      "components": [
        "AgentReasoningSection",
        "ToolCallsSection"
      ],
      "all_collapsible": true
    },
    
    "MetadataPanel": {
      "fields": [
        "trace_id",
        "customer_persona",
        "review_status",
        "reviewer",
        "reviewed_at"
      ]
    },
    
    "FeedbackPanel": {
      "components": [
        "StatusButtons",
        "NotesInput",
        "SaveIndicator"
      ]
    },
    
    "NavigationFooter": {
      "components": [
        "PreviousButton",
        "NextButton",
        "SkipDeferButton",
        "JumpToInput",
        "CurrentTraceIndicator"
      ],
      "layout": "horizontal",
      "sticky": true
    }
  },
  
  "component_specifications": {
    "SystemPromptSection": {
      "type": "collapsible",
      "default_state": "collapsed",
      "header": "📄 System Prompt",
      "content_source": "inferred_or_placeholder",
      "background_color": "gray-50"
    },
    
    "UserQuerySection": {
      "type": "static",
      "always_visible": true,
      "content_source": "trace.user_query",
      "style": {
        "font_size": "large",
        "font_weight": "bold",
        "background_color": "white",
        "padding": "large"
      }
    },
    
    "AgentReasoningSection": {
      "type": "collapsible",
      "default_state": "collapsed",
      "header": "▼ Agent Reasoning ({count} steps)",
      "content_source": "conversation_flow[type=message, role=AGENT|ASSISTANT]",
      "style": {
        "background_color": "blue-50",
        "font_size": "small"
      }
    },
    
    "ToolCallsSection": {
      "type": "collapsible",
      "default_state": "collapsed",
      "header": "▼ Tool Calls ({count} calls)",
      "content_source": "conversation_flow[type=tool_call]",
      "style": {
        "background_color": "yellow-50"
      },
      "item_rendering": {
        "success": {
          "icon": "✓",
          "icon_color": "green",
          "background": "white"
        },
        "error": {
          "icon": "❌",
          "icon_color": "red",
          "background": "red-100",
          "font_weight": "bold",
          "always_visible": true,
          "override_collapsed_state": true
        }
      }
    },
    
    "FinalResponseSection": {
      "type": "static",
      "always_visible": true,
      "header": "Final Response",
      "content_source": "conversation_flow[last_message]",
      "style": {
        "background_color": "white",
        "padding": "large"
      }
    },
    
    "StatusButtons": {
      "type": "button_group",
      "buttons": [
        {
          "label": "PASS",
          "value": "pass",
          "color": "green",
          "size": "large",
          "action": "set_status_and_save"
        },
        {
          "label": "FAIL",
          "value": "fail",
          "color": "red",
          "size": "large",
          "action": "set_status_and_save"
        },
        {
          "label": "DEFER",
          "value": "deferred",
          "color": "yellow",
          "size": "large",
          "action": "set_status_and_save"
        }
      ],
      "layout": "horizontal",
      "spacing": "medium"
    },
    
    "NotesInput": {
      "type": "textarea",
      "placeholder": "What went wrong? What did you observe?",
      "rows": 6,
      "autocomplete": {
        "enabled": true,
        "source": "previous_annotations.notes",
        "trigger": "as_you_type",
        "min_chars": 3
      },
      "auto_save": {
        "enabled": true,
        "trigger": "on_blur"
      }
    },
    
    "SaveIndicator": {
      "type": "status_badge",
      "states": {
        "saving": {
          "text": "Saving...",
          "icon": "spinner",
          "color": "gray"
        },
        "saved": {
          "text": "✓ Saved",
          "icon": "check",
          "color": "green"
        }
      }
    },
    
    "ProgressSummary": {
      "type": "stats_panel",
      "metrics": [
        {
          "label": "Total",
          "value": "{total_traces}",
          "format": "number"
        },
        {
          "label": "Reviewed",
          "value": "{reviewed_count}",
          "format": "number_with_percentage"
        },
        {
          "label": "Pass",
          "value": "{pass_count}",
          "color": "green"
        },
        {
          "label": "Fail",
          "value": "{fail_count}",
          "color": "red"
        },
        {
          "label": "Deferred",
          "value": "{deferred_count}",
          "color": "yellow"
        },
        {
          "label": "Remaining",
          "value": "{remaining_count}",
          "emphasis": true
        }
      ]
    },
    
    "SortDropdown": {
      "type": "dropdown",
      "label": "Sort by:",
      "options": [
        {
          "label": "Errors First (Recommended)",
          "value": "errors_first",
          "default": true
        },
        {
          "label": "Sequential (1, 2, 3...)",
          "value": "sequential"
        },
        {
          "label": "Random",
          "value": "random"
        },
        {
          "label": "Not Reviewed First",
          "value": "not_reviewed_first"
        }
      ],
      "on_change": "reorder_traces_and_reset_to_first"
    },
    
    "FilterPanel": {
      "type": "checkbox_group",
      "label": "Filter by:",
      "filters": [
        {
          "label": "Has tool errors ({count} traces)",
          "value": "has_errors",
          "filter_logic": "conversation_flow.any(is_error=true)"
        },
        {
          "label": "Review status",
          "type": "sub_filters",
          "options": [
            {"label": "Not reviewed", "value": "not_reviewed"},
            {"label": "Pass", "value": "pass"},
            {"label": "Fail", "value": "fail"},
            {"label": "Deferred", "value": "deferred"}
          ]
        }
      ],
      "display_count": {
        "enabled": true,
        "format": "Showing: {filtered_count} of {total_count} traces"
      }
    },
    
    "CurrentTraceIndicator": {
      "type": "text",
      "format": "Trace {current_index} of {total_count}",
      "style": {
        "font_weight": "bold",
        "font_size": "medium"
      }
    },
    
    "JumpToInput": {
      "type": "number_input_with_button",
      "label": "Jump to trace #",
      "button_label": "Go",
      "validation": {
        "min": 1,
        "max": "{total_traces}",
        "error_message": "Trace number must be between 1 and {total_traces}"
      },
      "action": "navigate_to_trace"
    }
  },
  
  "user_flows": {
    "initial_load": {
      "steps": [
        "user_uploads_csv",
        "parse_csv",
        "validate_columns",
        "generate_missing_trace_ids",
        "detect_tool_errors",
        "apply_default_sort_errors_first",
        "load_first_trace",
        "check_for_existing_annotations"
      ]
    },
    
    "review_trace": {
      "steps": [
        "display_current_trace",
        "user_reads_trace",
        "user_expands_collapsible_sections_as_needed",
        "user_clicks_status_button",
        "auto_save_status",
        "show_save_indicator",
        "user_types_notes",
        "autocomplete_suggests_previous_notes",
        "auto_save_on_blur",
        "user_clicks_next",
        "load_next_trace"
      ]
    },
    
    "edit_past_annotation": {
      "steps": [
        "user_navigates_to_previous_trace",
        "load_existing_annotation",
        "user_changes_status_or_notes",
        "create_revision_history_entry",
        "auto_save_changes",
        "display_edit_timestamp"
      ]
    },
    
    "filter_and_sort": {
      "steps": [
        "user_selects_sort_option",
        "reorder_traces",
        "reset_to_first_matching_trace",
        "user_checks_filter_options",
        "apply_filters",
        "update_trace_list",
        "update_count_display",
        "navigate_to_first_filtered_trace"
      ]
    }
  },
  
  "interactions": {
    "click_pass_button": {
      "trigger": "StatusButtons.PASS.click",
      "actions": [
        "set_annotation.status = 'pass'",
        "set_annotation.reviewed_at = now()",
        "save_annotation_to_storage",
        "update_progress_stats",
        "show_save_indicator.saved",
        "enable_next_button"
      ]
    },
    
    "click_fail_button": {
      "trigger": "StatusButtons.FAIL.click",
      "actions": [
        "set_annotation.status = 'fail'",
        "set_annotation.reviewed_at = now()",
        "save_annotation_to_storage",
        "update_progress_stats",
        "show_save_indicator.saved",
        "enable_next_button"
      ]
    },
    
    "click_defer_button": {
      "trigger": "StatusButtons.DEFER.click",
      "actions": [
        "set_annotation.status = 'deferred'",
        "set_annotation.reviewed_at = now()",
        "save_annotation_to_storage",
        "update_progress_stats",
        "show_save_indicator.saved",
        "enable_next_button"
      ]
    },
    
    "type_in_notes": {
      "trigger": "NotesInput.onChange",
      "actions": [
        "check_autocomplete_suggestions",
        "display_suggestions_dropdown",
        "on_blur: save_notes_to_annotation",
        "show_save_indicator.saving",
        "after_save: show_save_indicator.saved"
      ]
    },
    
    "click_next": {
      "trigger": "NextButton.click",
      "actions": [
        "increment_current_trace_index",
        "check_if_filtered",
        "load_next_matching_trace",
        "update_current_trace_indicator",
        "check_if_annotation_exists",
        "populate_feedback_panel_if_exists"
      ]
    },
    
    "click_previous": {
      "trigger": "PreviousButton.click",
      "actions": [
        "decrement_current_trace_index",
        "check_if_filtered",
        "load_previous_matching_trace",
        "update_current_trace_indicator",
        "load_existing_annotation",
        "populate_feedback_panel"
      ]
    },
    
    "click_skip_defer": {
      "trigger": "SkipDeferButton.click",
      "actions": [
        "set_annotation.status = 'deferred'",
        "save_annotation_to_storage",
        "increment_current_trace_index",
        "load_next_trace"
      ]
    },
    
    "jump_to_trace": {
      "trigger": "JumpToInput.submit",
      "actions": [
        "validate_trace_number",
        "if_valid: set_current_trace_index",
        "load_specified_trace",
        "update_current_trace_indicator",
        "load_existing_annotation_if_exists"
      ]
    },
    
    "toggle_collapsible_section": {
      "trigger": "CollapsibleSection.header.click",
      "actions": [
        "toggle_section.expanded_state",
        "animate_expand_collapse",
        "update_header_icon",
        "save_expanded_state_preference"
      ]
    },
    
    "change_sort": {
      "trigger": "SortDropdown.onChange",
      "actions": [
        "get_selected_sort_value",
        "apply_sort_logic",
        "reorder_trace_list",
        "set_current_trace_index = 0",
        "load_first_trace",
        "update_ui"
      ]
    },
    
    "toggle_filter": {
      "trigger": "FilterPanel.checkbox.onChange",
      "actions": [
        "get_active_filters",
        "apply_filter_logic",
        "update_filtered_trace_list",
        "update_count_display",
        "if_current_trace_filtered_out: navigate_to_first_matching",
        "update_ui"
      ]
    }
  },
  
  "storage": {
    "method": "localStorage",
    "keys": {
      "annotations": "trace_review_annotations",
      "preferences": "trace_review_preferences"
    },
    "auto_save": true,
    "backup": {
      "enabled": true,
      "trigger": "every_10_annotations",
      "method": "json_download"
    }
  },
  
  "parsing_logic": {
    "conversation_messages": {
      "steps": [
        {
          "step": "split",
          "delimiter": " | ",
          "result": "segments_array"
        },
        {
          "step": "detect_role",
          "pattern": "^(USER|ASSISTANT|AGENT):",
          "extract": "role"
        },
        {
          "step": "detect_tool_call",
          "pattern": "TOOL_CALL\\[([^\\]]+)\\]",
          "extract": "tool_name"
        },
        {
          "step": "detect_error",
          "keyword": "Error:",
          "set": "is_error = true"
        },
        {
          "step": "extract_content",
          "remove": "role_prefix",
          "result": "clean_content"
        }
      ]
    }
  },
  
  "error_handling": {
    "csv_parsing_failed": {
      "message": "Unable to parse CSV. Please check the file format.",
      "action": "show_error_modal_with_retry"
    },
    "missing_required_column": {
      "message": "CSV is missing required column: {column_name}",
      "action": "show_error_modal"
    },
    "trace_navigation_out_of_bounds": {
      "message": "Cannot navigate beyond trace list",
      "action": "disable_navigation_button"
    },
    "save_failed": {
      "message": "Failed to save annotation. Retrying...",
      "action": "retry_save_with_exponential_backoff"
    }
  },
  
  "visual_design": {
    "theme": "clean_minimal",
    "color_palette": {
      "status_pass": "#22c55e",
      "status_fail": "#ef4444",
      "status_deferred": "#f59e0b",
      "error_highlight": "#fee2e2",
      "reasoning_background": "#dbeafe",
      "tool_calls_background": "#fef3c7",
      "neutral_background": "#f9fafb"
    },
    "typography": {
      "user_query": {
        "size": "xl",
        "weight": "bold"
      },
      "agent_reasoning": {
        "size": "sm"
      },
      "tool_errors": {
        "size": "base",
        "weight": "bold"
      }
    },
    "spacing": {
      "sections": "large",
      "components": "medium",
      "inline": "small"
    }
  }
}
